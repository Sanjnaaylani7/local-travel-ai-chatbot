# -------- Application --------
APP_NAME=Local Travel AI Chatbot
APP_VERSION=1.0.0
ENV=development
LOG_LEVEL=INFO

# -------- Server --------
HOST=0.0.0.0
PORT=8000
UVICORN_WORKERS=2

# -------- CORS --------
# Comma-separated list of allowed origins. Use your website URL(s) in production.
# Example: CORS_ORIGINS=https://rehmantravel.com,https://www.rehmantravel.com
CORS_ORIGINS=*

# -------- Database --------
# SQLite by default; switch to Postgres in production, e.g.
# DATABASE_URL=postgresql+psycopg://user:pass@db:5432/travel
DATABASE_URL=sqlite:///./data/app.db

# -------- Model server --------
MODEL_URL=http://localhost:8001/infer
MODEL_TIMEOUT=60
MODEL_MAX_RETRIES=2
MODEL_NAME=google/flan-t5-small

# -------- Embeddings / retrieval --------
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
VECTOR_STORE_DIR=./data_pipeline/output/vector_store
TOP_K=4
SIMILARITY_THRESHOLD=0.30

# -------- Conversation --------
MAX_HISTORY_TURNS=4

# -------- Security / ops --------
# Required to access admin endpoints (e.g. feedback export). Leave empty to disable them.
ADMIN_API_KEY=
RATE_LIMIT_PER_MINUTE=60
ENABLE_METRICS=true

# -------- Data pipeline --------
CRAWL_BASE_URL=https://rehmantravel.com
CRAWL_MAX_PAGES=50
